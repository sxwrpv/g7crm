            { "name": "message", "value": "={{$json.message}}" },
            { "name": "source_channel", "value": "={{$json.source_channel}}" },
            { "name": "submission_status", "value": "new" },
            { "name": "n8n_run_id", "value": "={{$json.run_id}}" },
            { "name": "raw_payload", "value": "={{$json}}" }
          ]
        }
      },
