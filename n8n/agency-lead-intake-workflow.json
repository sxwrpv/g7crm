        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const body = $json.body ?? $json;\nconst now = new Date();\nconst leadName = body.name ?? body.lead_name ?? 'Unknown Lead';\nconst businessName = body.business_name ?? body.company ?? body.account_name ?? 'Unknown Business';\nconst leadService = body.service ?? body.lead_service ?? body.service_requested ?? 'General enquiry';\nconst leadEmail = body.email ?? body.lead_email ?? null;\nconst leadPhone = body.phone ?? body.lead_phone ?? null;\nconst urgency = body.urgency ?? 'normal';\nconst sourceChannel = body.source_channel ?? body.lead_source ?? 'website-form';\nconst message = body.message ?? body.lead_message ?? body.notes ?? '';\nconst assignedTo = body.assigned_to ?? 'ops';\nconst alertDestination = body.alert_destination ?? '@sxwrpv1';\nconst niche = body.niche ?? 'Home Services';\nreturn { json: {\n  received_at: now.toISOString(),\n  run_id: `run_${Date.now()}`,\n  lead_name: leadName,\n  business_name: businessName,\n  lead_email: leadEmail,\n  lead_phone: leadPhone,\n  lead_service: leadService,\n  service_requested: leadService,\n  urgency,\n  source_channel: sourceChannel,\n  message,\n  assigned_to: assignedTo,\n  alert_destination: alertDestination,\n  niche\n} };"
      },
      "id": "normalize-node",
      "name": "Normalize Lead Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 260]
    },
    {
