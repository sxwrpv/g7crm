      },
      "id": "d16ace2d-4bad-4a8e-8348-f7b74357052c",
      "name": "Twilio WhatsApp Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-820, 0],
      "webhookId": "whatsapp-lead-intake"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const body = $json.body ?? $json;\nconst fromRaw = String(body.From ?? body.phone ?? '').trim();\nconst phone = fromRaw.replace(/^whatsapp:/i, '');\nconst message = String(body.Body ?? body.message ?? '').trim();\nconst profileName = String(body.ProfileName ?? body.name ?? '').trim();\nconst messageSid = String(body.MessageSid ?? body.message_sid ?? `WA_${Date.now()}`);\nif (!phone) throw new Error('WhatsApp sender phone is missing');\nif (!message && Number(body.NumMedia ?? 0) === 0) throw new Error('WhatsApp message body is missing');\nreturn { json: {\n  phone,\n  message: message || 'Customer sent a WhatsApp media attachment.',\n  profile_name: profileName,\n  message_sid: messageSid,\n  dry_run: body.dry_run === true || String(body.dry_run ?? '').toLowerCase() === 'true'\n} };"
      },
      "id": "576c3e16-ff87-42a8-b7e0-d2cb565ae36e",
      "name": "Normalize WhatsApp Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-600, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8766/analyze",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            { "name": "phone", "value": "={{$json.phone}}" },
            { "name": "message", "value": "={{$json.message}}" },
            { "name": "profile_name", "value": "={{$json.profile_name}}" },
            { "name": "message_sid", "value": "={{$json.message_sid}}" }
          ]
        },
        "options": { "timeout": 120000 }
      },
      "id": "972d5464-e45a-4e7e-a03b-1cd95af77e2d",
      "name": "AI Analyse Full Chat",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-380, 0]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const ai = $json;\nconst inbound = $node['Normalize WhatsApp Message'].json;\nconst lead = ai.lead ?? {};\nconst xmlEscape = (value) => String(value ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\\\"/g, '&quot;').replace(/'/g, '&apos;');\nconst details = [\n  `Issue: ${lead.issue_description || lead.service_requested || 'WhatsApp enquiry'}`,\n  `Location: ${lead.location || lead.postcode || 'Not supplied'}`,\n  `Urgency: ${lead.urgency || 'normal'}`,\n  `Preferred timing: ${[lead.preferred_date, lead.preferred_time, lead.timing_notes].filter(Boolean).join(' ') || 'Not supplied'}`,\n  `Budget/price: ${lead.budget_text || lead.price_value || lead.price_preference || 'Not supplied'}`,\n  `Property: ${lead.property_type || 'Not supplied'}`,\n  `Access notes: ${lead.access_notes || 'None supplied'}`,\n  `AI summary: ${ai.summary || ''}`\n].join('\\n');\nreturn { json: {\n  phone: inbound.phone,\n  message_sid: inbound.message_sid,\n  dry_run: inbound.dry_run,\n  reply: ai.reply,\n  twiml: `<?xml version=\"1.0\" encoding=\"UTF-8\"?><Response><Message>${xmlEscape(ai.reply)}</Message></Response>`,\n  should_submit: Boolean(ai.should_submit && !inbound.dry_run && !ai.duplicate),\n  lead_name: lead.name || inbound.profile_name || inbound.phone,\n  business_name: `WhatsApp Lead - ${lead.name || inbound.profile_name || inbound.phone}`,\n  email: lead.email || null,\n  service_requested: lead.service_requested || 'WhatsApp enquiry',\n  urgency: lead.urgency || 'normal',\n  preferred_date: lead.preferred_date || null,\n  preferred_time: lead.preferred_time || null,\n  structured_message: details,\n  source_channel: 'whatsapp',\n  assigned_to: 'ops',\n  alert_destination: $vars.g7TelegramTarget ?? 'CONFIGURE_IN_N8N',\n  ai_summary: ai.summary || 'WhatsApp AI intake',\n  missing_required: ai.missing_required || [],\n  lead_complete: Boolean(ai.lead_complete),\n  confirmed: Boolean(ai.confirmed)\n} };"
      },
      "id": "fd890b86-e334-4f7b-b132-70b85ee87777",
      "name": "Build AI Reply + Lead Payload",
      "type": "n8n-nodes-base.code",
