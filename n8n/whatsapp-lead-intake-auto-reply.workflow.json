{
  "id": "whatsapp-lead-intake-auto-reply",
  "name": "WhatsApp AI Lead Intake + Auto Reply",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-lead-intake",
        "responseMode": "responseNode",
